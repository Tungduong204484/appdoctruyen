<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.appctruyn">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Appctruyn">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible" />

        <activity
            android:name=".CommentsActivity"
            android:exported="false"
            android:label="Bình luận" />

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".StoryDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ReadChapterActivity"
            android:exported="false" />

        <activity
            android:name=".AdminManageUsersActivity"
            android:exported="false"
            android:label="@string/manage_users" />

        <activity
            android:name=".AddStoryActivity"
            android:exported="false"
            android:label="Đăng truyện mới" />

        <activity
            android:name=".MyStoriesActivity"
            android:exported="false"
            android:label="Truyện của tôi" />

        <activity
            android:name=".AdminManageStoriesActivity"
            android:exported="false"
            android:label="Quản lý toàn bộ truyện" />

        <activity
            android:name=".AddChapterActivity"
            android:exported="false"
            android:label="Thêm chương mới" />

    </application>

</manifest>