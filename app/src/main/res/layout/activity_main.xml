<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@color/bg_dark">

            <!-- Trái: Avatar + Dropdown -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Avatar nữ (tím) -->
                <ImageView
                    android:id="@+id/avatarFemale"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_avatar_female"
                    android:background="@drawable/bg_avatar_purple"
                    android:padding="6dp"
                    android:layout_marginEnd="-10dp"
                    android:elevation="2dp" />

                <!-- Avatar nam (xanh) -->
                <ImageView
                    android:id="@+id/avatarMale"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_avatar_male"
                    android:background="@drawable/bg_avatar_blue"
                    android:padding="6dp" />

                <!-- Dropdown "Tất cả ˅" -->
                <LinearLayout
                    android:id="@+id/dropdownFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tất cả"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_down"
                        android:layout_marginStart="3dp"
                        android:tint="@color/text_primary" />
                </LinearLayout>

            </LinearLayout>

            <!-- Phải: Search + Filter -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="end">

                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_search"
                    android:padding="9dp"
                    android:tint="@color/text_primary"
                    android:background="@drawable/bg_icon_btn"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/btnFilter"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_filter"
                    android:padding="9dp"
                    android:tint="@color/text_primary"
                    android:background="@drawable/bg_icon_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Tab Layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        app:tabIndicatorColor="#FF5722"
        app:tabSelectedTextColor="#FF5722"
        app:tabTextColor="#666666"
        app:tabMode="scrollable" />

    <!-- ViewPager -->
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_icon_color"
        app:itemTextColor="@color/bottom_nav_text_color"
        app:labelVisibilityMode="labeled"
        app:elevation="8dp" />

</LinearLayout>

