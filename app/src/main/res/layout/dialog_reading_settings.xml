<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/divider" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reading_settings"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Cỡ chữ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cỡ chữ"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderTextSize"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="14"
            android:valueTo="32"
            android:stepSize="1"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="22sp"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Phông chữ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phông chữ"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleFont"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnFontSans"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Không chân"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnFontSerif"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Có chân"
            android:textAllCaps="false" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Chế độ đọc -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chế độ đọc"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleTheme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btnThemeLight"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sáng"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnThemeSepia"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Giấy cũ"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnThemeDark"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tối"
            android:textAllCaps="false" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>