<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Tab Layout: Chỉ còn 3 mục Đề cử, Bình luận, Lượt đọc.
         Bỏ hiệu ứng Ripple tối màu (RippleColor transparent) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutRanking"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:tabIndicatorColor="@color/primary"
        app:tabIndicatorHeight="2dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabRippleColor="@android:color/transparent"
        app:tabBackground="@android:color/transparent"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabTextAppearance="@style/RankingTabText"
        app:tabTextColor="@color/text_secondary" />

    <!-- ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerRanking"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
